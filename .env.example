# ------------------------------------------------------------
# アプリ起動用の環境変数テンプレート
# このファイルを .env にコピーして値を入力してください
# .env は Git 管理対象外です（コミットしない）
# ------------------------------------------------------------

# 必須: 実行環境（dev または prod）
APP_ENV=dev

# .env.shared が先に読み込まれ、この .env で同名キーを上書きできます

# ------------------------------------------------------------
# Terraform / Snowflake 実行設定
# ------------------------------------------------------------
# 任意: Terraform 実行用 Snowflake ユーザー（未指定時は HCP Workspace Variables を使用）
SNOWFLAKE_USER=YOUR_TERRAFORM_USER
# 任意: Terraform 実行用 Snowflake 秘密鍵
SNOWFLAKE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"
# 任意: 明示したい場合のみ設定（通常は SNOWFLAKE_ACCOUNT から自動分解）
# SNOWFLAKE_ORGANIZATION_NAME=YOUR_ORG_NAME
# SNOWFLAKE_ACCOUNT_NAME=YOUR_ACCOUNT_NAME
# 任意: 認証方式
SNOWFLAKE_AUTHENTICATOR=SNOWFLAKE_JWT

# ------------------------------------------------------------
# Snowflake 共通
# ------------------------------------------------------------
# 必須: Snowflake アカウント識別子（例: XXXXXXX-XXXXXXXX）
SNOWFLAKE_ACCOUNT=YOUR-ACCOUNT-ID

# ------------------------------------------------------------
# ローダーユーザー（src/infrastructure/snowflake_loader.py）
# Bronze 層への書き込み用
# ------------------------------------------------------------
# 必須: dev ローダー接続情報
DEV_LOADER_USER_RSA_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"

# 必須: prod ローダー接続情報
PROD_LOADER_USER_RSA_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"

# ------------------------------------------------------------
# dbt 実行ユーザー（enterprise_data_pipeline/profiles.yml, run_dbt.py）
# ------------------------------------------------------------
# 必須: dev dbt 接続情報
DEV_DBT_USER_RSA_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"

# 必須: prod dbt 接続情報
PROD_DBT_USER_RSA_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"

# ------------------------------------------------------------
# Streamlit ユーザー（src/streamlit/app.py）
# Gold 層の参照用
# ------------------------------------------------------------
# 必須: dev Streamlit 接続情報
DEV_STREAMLIT_USER_RSA_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"

# 必須: prod Streamlit 接続情報
PROD_STREAMLIT_USER_RSA_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"

# ------------------------------------------------------------
# Terraform メモ
# TF_VAR_* は可能な限り HCP Terraform Workspace Variables を使用
# 共有する .env に機密情報を直接保持しない
# ------------------------------------------------------------
